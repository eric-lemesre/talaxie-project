# =============================================================================
# Talaxie — Deployment / infrastructure credentials
# =============================================================================
# Copy this file to infra/.env and fill in the values for your deployment
# context. NEVER commit infra/.env (already covered by .gitignore .env*).
#
# This file is consumed by infra/migrate-to-vps.sh and is intended to be
# transferred to the target VPS along with the rest of the project before
# running the migration script.
# =============================================================================

# --- OVH API (production hosting / DNS automation) --------------------------
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=

# --- Source WordPress hosting (talaxie.org production) ----------------------
TALAXIE_ORG_HOME=
TALAXIE_ORG_SSH_HOST=
TALAXIE_ORG_FTP_URL=
TALAXIE_ORG_FTP_USER=
TALAXIE_ORG_FTP_PSWD=

# --- Source database (talaxie.org production) ------------------------------
TALAXIE_ORG_DB_TYPE=mysql
TALAXIE_ORG_DB_HOST=
TALAXIE_ORG_DB_PORT=3306
TALAXIE_ORG_DB_NAME=
TALAXIE_ORG_DB_USER=
TALAXIE_ORG_DB_PSWD=

# --- WordPress admin (production) -------------------------------------------
WP_ADMIN_USER=
WP_APP_PSDW=
