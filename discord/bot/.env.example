# Discord Bot Token — NE JAMAIS COMMITTER LE VRAI TOKEN
# Obtenir sur : https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# ID du serveur Discord (Guild ID)
GUILD_ID=123456789012345678

# ID du salon d'accueil pour les logs de bienvenue
WELCOME_CHANNEL_ID=123456789012345678

# ID du salon de modération pour les alertes
MOD_LOG_CHANNEL_ID=123456789012345678

# ID du salon sécurité pour les alertes credentials
SECURITY_ALERT_CHANNEL_ID=123456789012345678

# Rôle attribué automatiquement après acceptation du règlement
NEW_MEMBER_ROLE_ID=123456789012345678

# GitHub repository (pour la commande /issue)
GITHUB_REPO=Talaxie

# URL de la documentation Docusaurus (pour la commande /doc)
DOCS_URL=https://docs.talaxie.org
