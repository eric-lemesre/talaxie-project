# =============================================================================
# Talaxie — Local development environment
# =============================================================================
# Copy this file to .env and adjust values for your local setup.
# NEVER commit .env (already in .gitignore).
# =============================================================================

# --- WordPress URL ----------------------------------------------------------
# Must match your local web server vhost / /etc/hosts entry.
WP_HOME=http://talaxie.test
WP_SITEURL=http://talaxie.test
WP_TITLE="Talaxie Community (dev)"
WP_LOCALE=fr_FR

# --- WordPress admin (created on first install) -----------------------------
# Change WP_ADMIN_PASSWORD before bootstrapping.
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=changeme
WP_ADMIN_EMAIL=admin@talaxie.test

# --- WordPress runtime ------------------------------------------------------
WP_DEBUG=true
WP_TABLE_PREFIX=tlx_

# --- Database (local MariaDB/MySQL must be running) -------------------------
# Change DB_PASSWORD before bootstrapping.
DB_NAME=talaxie_dev
DB_USER=talaxie_dev
DB_PASSWORD=changeme
DB_HOST=localhost
DB_CHARSET=utf8mb4
DB_COLLATE=utf8mb4_unicode_520_ci

# --- Optional: MySQL root credentials ---------------------------------------
# If set, bin/bootstrap.sh will create the database and user automatically.
# If unset, bootstrap will print SQL commands to run manually as root.
#DB_ROOT_USER=root
#DB_ROOT_PASSWORD=

# --- Talaxie component repositories -----------------------------------------
# Override these only if you fork the theme or plugin. Default values point
# to the canonical repositories.
#TALAXIE_THEME_REPO=git@github.com:eric-lemesre/talaxie-wp-theme.git
#TALAXIE_CORE_REPO=git@github.com:eric-lemesre/talaxie-wp-core.git

# --- Optional: install the MCP stack ----------------------------------------
# Set TALAXIE_INSTALL_MCP=true to make bin/bootstrap.sh clone, install and
# activate WordPress/mcp-adapter so you can drive the site from Claude Code
# (or any MCP client). The WordPress Abilities API itself is part of WP 6.9
# core (wp-includes/abilities-api.php) and needs no separate install.
# After bootstrap, see docs/mcp-setup.md for the Nginx fix and Claude Code
# registration command.
TALAXIE_INSTALL_MCP=false

# Application password used by external MCP / REST clients for HTTP Basic auth.
# Generate with: wp user application-password create admin 'Claude Code MCP' --porcelain
# Leave empty until you have actually created one.
WP_ADMIN_APP_PASSWORD=
